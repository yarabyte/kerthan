# URL publique du site (domaine de production)
NEXT_PUBLIC_SITE_URL=https://www.kerthan.org

# Mode maintenance — fallback si la base est indisponible (true | false)
MAINTENANCE_MODE=false

# PostgreSQL — base Coolify (service lié au projet)
# Ex. interne Coolify : postgresql://user:pass@nom-du-service-postgres:5432/kerthan
DATABASE_URL=

# Backoffice — 1 compte admin
ADMIN_EMAIL=webmaster@kerthan.org
# Générer avec : npm run admin:hash -- VotreMotDePasse
ADMIN_PASSWORD_HASH_B64=

# Session admin (min. 32 caractères aléatoires)
SESSION_SECRET=

# SMTP — envoi des demandes de rendez-vous (page contact)
SMTP_HOST=smtp.siteprotect.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=webmaster@kerthan.org
SMTP_PASSWORD=
SMTP_FROM=Clinique Kerthan <webmaster@kerthan.org>
CONTACT_TO=webmaster@kerthan.org
